{
  "name": "monochrome-mobile",
  "version": "2.5.0",
  "description": "Monochrome Music — Native mobile app powered by Capacitor",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "node scripts/build-shell.js",
    "cap:sync": "npx cap sync",
    "cap:update": "npx cap update",
    "ios": "npx cap open ios",
    "android": "npx cap open android",
    "build:ios": "npm run build:web && npx cap sync ios",
    "build:android": "npm run build:web && npx cap sync android",
    "prepare": "npm run build:web"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/browser": "^7.0.0",
    "@capacitor/clipboard": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/local-notifications": "^7.0.0",
    "@capacitor/network": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@capacitor/screen-orientation": "^7.0.0",
    "@capacitor/share": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@capacitor/toast": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0"
  }
}
